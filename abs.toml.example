config_version = 1

# ABS example config. Copy to ~/.config/abs/abs.toml or /etc/abs/abs.toml.

# Self-Updates (Root-level configurations)
# check_for_update_on_startup = true
# auto_update_on_startup = false
# self_update_at_updates = false
# self_update_raw_url = "https://raw.githubusercontent.com/John-CPP/ABS/HEAD/Cargo.toml"
# self_update_use_pacman = true   # default: auto (use pacman when abs/absgui packages are installed)
# self_update_install_path = "/usr/bin/abs"  # fallback when self_update_use_pacman = false
# If false, checks for newer versions of Arch Linux or CachyOS packages using stable pacman sync databases instead of git.
# install_testing_phase_archlinux_packages = false

manual_update_packages = [
]
# Packages excluded from system update (repo binaries), via pacman/yay --ignore.
# Glob patterns are supported: "qemu*" matches all repo/installed names starting with qemu.
skip_install_packages = [
]
# Packages excluded from pacman -U after manual compilation (omit to inherit skip_install_packages).
skip_install_packages_after_compilation = [
]

[paths]
packages_path = "$XDG_CONFIG_HOME/.cache/abs/packages"
chroot_base_path = "$XDG_CONFIG_HOME/.cache/abs/chroot"
ready_made_packages_path = "$XDG_CONFIG_HOME/.cache/abs/ready"
# Optional: path to a custom makepkg.conf file to inject into the chroot container
# chroot_makepkg_conf = "~/.config/abs/makepkg.conf"

# Optional tmpfs/ramdisk: speeds up builds and reduces disk wear.
# Disk [paths] remain the persistent locations; ramdisk holds ephemeral compile state.
# Set enabled = true, then turn on individual targets (build_workdir, chroot, packages).
[ramdisk]
# Enable tmpfs/ramdisk support (requires sudo when a package task opts in via global or per-package
# targets). Tmpfs is mounted lazily on the first build/download that needs it, not at ABS startup.
enabled = false
# Absolute path where tmpfs is mounted for this ABS run (must not be a system root like / or /run).
mount_point = "/run/abs-ram"
# Maximum tmpfs size passed to mount -o size= (cap, not pre-allocated). Increase for large builds or parallel chroot workers.
size = "16G"
# Directory permissions for the tmpfs mount root (octal, e.g. 0755).
mode = "0755"
# During each build, symlink src/ and pkg/ under the package directory to per-package dirs on tmpfs (compile I/O in RAM).
# Default for all packages when no per-package override is set. Use per-package `ramdisk = "wcp"` to override.
build_workdir = false
# Use tmpfs for chroot_base_path during makechrootpkg (-h) builds instead of the disk path in [paths].
chroot = false
# Use tmpfs for the entire packages_path (git clones and sources). High RAM use; off by default.
packages = false
# Optional disk directory to rsync into the ram chroot before first use (copies the entire tree; leave unset for a fresh mkarchroot on RAM).
# seed_chroot_from = ""
# On normal ABS exit, rsync the ram chroot back to seed_chroot_from when sync_chroot_on_exit = true (requires seed_chroot_from).
sync_chroot_on_exit = false
# Refuse to mount tmpfs when MemAvailable in /proc/meminfo is below this value (MiB).
min_free_ram_mb = 4096
# Print a warning when packages = true because full-repo-on-RAM can consume many gigabytes.
warn_packages_ram = true
# Unmount mount_point before mounting when it is already mounted (cleans up after a crashed ABS run).
reclaim_mount_on_startup = true

[build]
default_environment = "local"
ignore_compilation_failures = false
compile_first_install_after = false
clean_install_by_default = false
# When false (default), skip compilation if matching .pkg.tar.* already exist in
# ready_made_packages_path and install those instead (unless -o). Use -n or set true to force rebuild.
ignore_already_made_packages = false
concurrent_repos_downloads_limit = 10
# Maximum number of clean chroot compilations to run concurrently
concurrent_compilations_limit = 1
# Check AUR package versions using the AUR RPC API in batch
fast_aur_rpc_update_checks = true
# Perform system update before compiling packages (highly recommended to prevent broken shared libraries)
system_update_first = true
# After each chroot (makechrootpkg) build, remove working copies and reset the devtools chroot when idle
clean_chroot_after_compilation = true
# CPU-aware scheduler: strict = hard cap on sum of active threads; flexible = soft cap + optional burst
# global_cpu_threads_mode = "strict"
# global_cpu_threads_cap = 10
# maximum_cpu_threads_cap = 15   # flexible mode only
# default_compilation_threads = 5

[system_update]
command_to_update_repositories = "sudo pacman -Sy"
command_to_perform_system_update = "sudo pacman -Syu"
command_to_perform_system_update_no_refresh = "sudo pacman -Su"
ignore_flag = "--ignore"
ignore_packages = []

[repositories]
arch = "https://gitlab.archlinux.org/archlinux/packaging/packages"
aur = "https://aur.archlinux.org"
cachyos = "https://github.com/CachyOS/CachyOS-PKGBUILDS.git"
default = "arch"

[packages]

# Example: build an AUR package (or use `abs --repo=aur xray` without config entry).
# Optional: on `-RU`, check GitHub for newer (including pre-)releases and bump PKGBUILD before build.
# [packages.xray]
# source = "aur"
# upstream_github = "xtls/xray-core"
# upstream_prereleases = true
# build_env = "local"
# tests = true
# Override [build].ignore_already_made_packages for this package (true = always rebuild).
# ignore_already_made_packages = true
# pre_update_command = "rm -rf mozbuild"
# post_update_command = ""
# Per-package ramdisk targets when [ramdisk].enabled = true (replaces global build_workdir/chroot/packages for this package):
# w = build workdir (src/, pkg/), c = chroot, p = packages (git clone on tmpfs). Example: ramdisk = "wcp"
# ramdisk = "disabled"  # force disk-only for this package (same as ramdisk = "")
# ramdisk = "wcp"
# Or on the CLI (quote in zsh): abs 'mesa[ramdisk=wcp]'  /  abs 'electron40[ramdisk=disabled]'
# Or without brackets: abs --ramdisk=wcp mesa  /  abs --ramdisk=disabled electron40

# Example: CachyOS kernel 3-stage PGO (AutoFDO + Propeller)
# [packages.linux-cachyos]
# source = "aur"
# build_env = "local"
# compilation_threads = 8
# compile_alone = true
# compilation_priority = 10
# ramdisk = "w"
#
# [packages.linux-cachyos.kernel]
# _cpusched = "cachyos"
# _processor_opt = "native"
#
# [packages.linux-cachyos.pgo]
# enabled = true
# profiles_archive_dir = "/mnt/hdd/abs/pgo/profiles"
# benchmark_command = "/path/to/custom-benchmark.sh"  # optional; default is bundled assets/pgo-benchmark.sh
# profiling_quality = "maximum"  # standard | maximum (default: maximum)
# perf_extra_args = "--mmap-pages 131072 -a -N -b -c 48000"  # override auto quality tuning
# build_user = "john"
# sysctl_command = "cachyos-perf-sysctl"
# auto_restart = false  # reboot + resume via user systemd until PGO completes (--pgo-auto)
