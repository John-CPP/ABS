# abs.config
# -------------------------------------------------
# Paths
# -------------------------------------------------

PACKAGES_PATH="/media/storage/packages/my"
CHROOT_BASE_PATH="/media/storage/packages/my/chroot"
READY_MADE_PACKAGES_PATH="/media/storage/packages/abs_ready"

# Derived paths
MASTER_CHROOT="${CHROOT_BASE_PATH}/base"

# -------------------------------------------------
# Build Environment Defaults
# -------------------------------------------------
# The default build environment if no flag (-l or -h) is provided.
# Valid values: "local" or "chroot"
DEFAULT_BUILD_ENVIRONMENT="local"

# Package-specific build environments. Overrides the default.
# Overridden if a flag (-l or -h) is explicitly passed.
declare -A PACKAGE_BUILDING_ENVIRONMENT
# Example: PACKAGE_BUILDING_ENVIRONMENT["firefox-pure"]="chroot"
PACKAGE_BUILDING_ENVIRONMENT["firefox-pure"]="local"

# -------------------------------------------------
# Repositories
# -------------------------------------------------
declare -A REPOSITORIES
REPOSITORIES["arch"]="https://gitlab.archlinux.org/archlinux/packaging/packages"
REPOSITORIES["cachyos"]="https://github.com/CachyOS/CachyOS-PKGBUILDS.git"
REPOSITORIES["ventureoo"]="https://github.com/ventureoo/PKGBUILDs.git"
REPOSITORIES["venomo"]="https://github.com/Ven0m0/PKG.git"

DEFAULT_REPOSITORY="arch"

# -------------------------------------------------
# Package Sources
# -------------------------------------------------
# Define which repository a package should be pulled from.
# If not defined here, the script defaults to DEFAULT_REPOSITORY
declare -A PACKAGE_SOURCES
PACKAGE_SOURCES["systemd"]="arch"
PACKAGE_SOURCES["qemu-full"]="arch"
PACKAGE_SOURCES["firefox-pure"]="ventureoo"

# PACKAGE_SOURCES["linux-cachyos"]="cachyos"

# -------------------------------------------------
# Custom Build Commands
# -------------------------------------------------
# Allows overriding the default build commands
# Useful for passing environment variables or extra flags
declare -A CUSTOM_LOCAL_BUILD_COMMANDS
declare -A CUSTOM_CHROOT_BUILD_COMMANDS

# Example: Local builds can take env vars directly
# CUSTOM_LOCAL_BUILD_COMMANDS["firefox"]="ENABLE_BOLT=true makepkg --syncdeps --noconfirm --needed -f"

# Example: Chroot builds isolate the environment. To pass an env var, inject it into the PKGBUILD first:
# CUSTOM_CHROOT_BUILD_COMMANDS["qemu-full"]="sed -i '1i export ENABLE_BOLT=true' PKGBUILD && makechrootpkg -c -r \"\$MASTER_CHROOT\" -d \"\$PWD\""

# -------------------------------------------------
# Pre/Post Commands
# -------------------------------------------------
declare -A PRE_UPDATE_COMMANDS
declare -A POST_UPDATE_COMMANDS

# Example format:
# PRE_UPDATE_COMMANDS["pkgname"]="echo pre"
# POST_UPDATE_COMMANDS["pkgname"]="echo post"

# -------------------------------------------------
# System Update Config
# -------------------------------------------------
# Command to use for system update WITHOUT repository refresh (-U)
SYSTEM_UPDATE_COMMAND="sudo pacman -Sy"
# Command to use for full system update WITH repository refresh (-U -R)
SYSTEM_UPDATE_WITH_REPOSITORY_REFRESH_COMMAND="sudo pacman -Syu"

# Parameter to use to ignore a package during system update
# For pacman and yay, this is usually "--ignore"
SYSTEM_UPDATE_IGNORE_FLAG="--ignore"

# Array of packages to completely ignore during a full system update (-U)
# These will be appended to the pacman command alongside manually compiled packages
SYSTEM_UPDATE_IGNORE_PACKAGES=("firefox" "firefox-pure")

# Array of packages to manually compile when performing a full system update (-U)
MANUAL_UPDATE_PACKAGES=("systemd" "qemu-full")

# -------------------------------------------------
# Package Name Aliases (Base Package Maps)
# -------------------------------------------------
# Maps a sub-package name to its base package name in the repository.
# Example: qemu-full is a sub-package generated by building the 'qemu' PKGBUILD.
declare -A PACKAGE_ALIASES
PACKAGE_ALIASES["qemu-full"]="qemu"

# -------------------------------------------------
# Skip Installation
# -------------------------------------------------
# Array of sub-packages that should be ignored during installation
SKIP_INSTALL_PACKAGES=("systemd-tests" "qemu-user-static-binfmt" "qemu-user-static" "qemu-guest-agent")
